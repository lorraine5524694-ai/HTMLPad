{
  "name": "htmlpad",
  "version": "1.0.2",
  "description": "HTMLPad - HTML 双向编辑与阅读工具 for Mac",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac"
  },
  "keywords": ["html", "editor", "reader", "mac", "electron", "monaco"],
  "author": "Lorraine",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "monaco-editor": "^0.45.0",
    "dompurify": "^3.0.6",
    "html-to-image": "^1.11.11",
    "prettier": "^3.1.1"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.lorraine.htmlpad",
    "productName": "HTMLPad",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": ["dmg", "zip"],
      "extendInfo": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "HTMLPad HTML Document",
            "CFBundleTypeRole": "Editor",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": ["public.html"],
            "CFBundleTypeExtensions": ["html", "htm"]
          }
        ]
      },
      "fileAssociations": [
        {
          "ext": "html",
          "name": "HTMLPad HTML Document",
          "role": "Editor",
          "icon": "assets/icon.png"
        },
        {
          "ext": "htm",
          "name": "HTMLPad HTML Document",
          "role": "Editor",
          "icon": "assets/icon.png"
        }
      ]
    },
    "files": [
      "main.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
